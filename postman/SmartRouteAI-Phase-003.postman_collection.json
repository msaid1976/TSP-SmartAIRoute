  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "API Health Check",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"API health is 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "health"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Web Job Page Placeholder",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{webBaseUrl}}/jobs/{{jobId}}",
              "host": [
                "{{webBaseUrl}}"
              ],
              "path": [
                "jobs",
                "{{jobId}}"
              ]
            },
            "description": "Open this URL in your browser after a job is created."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Text Problem Flow",
      "item": [
        {
          "name": "Create Problem - Text Benchmark",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Problem created\", function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json();",
                  "  pm.collectionVariables.set(\"problemId\", data.problemId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"inputType\": \"text\",\n  \"name\": \"Phase 003 Text Benchmark\",\n  \"payload\": \"A(565,575), B(25,185), C(345,750), D(945,685), E(845,655), F(880,660), G(25,230), H(525,1000), I(580,1175), J(650,1130)\",\n  \"objective\": \"min_distance\",\n  \"returnToStart\": true\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/problems",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "problems"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Create Job - All Phase 003 Solvers",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Job queued\", function () {",
