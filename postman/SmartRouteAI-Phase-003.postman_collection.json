                  "});",
                  "if (pm.response.code === 202) {",
                  "  const data = pm.response.json();",
                  "  pm.collectionVariables.set(\"jobId\", data.jobId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"problemId\": \"{{problemId}}\",\n  \"solvers\": [\"ortools\", \"ga\", \"aco\"],\n  \"mode\": \"compare\",\n  \"seed\": 42\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
